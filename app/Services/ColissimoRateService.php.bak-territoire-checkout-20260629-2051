<?php

namespace App\Services;

use App\Models\Listing;
use RuntimeException;

class ColissimoRateService
{
    public function calculateForListing(Listing $listing, array $address): float
    {
        $weight = (float) ($listing->weight_kg ?: 0.5);

        $sellerTerritory = $this->normalizeTerritory($listing->territoire ?: 'La Réunion');
        $buyerCountry = $this->normalizeCountry((string) ($address['shipping_country'] ?? 'FR'));
        $buyerPostal = (string) ($address['shipping_postal_code'] ?? '');

        $zone = $this->resolveZone($sellerTerritory, $buyerCountry, $buyerPostal);

        $ht = $this->priceHt($zone, $weight);

        // TVA Réunion 8,5% pour affichage/facturation acheteur.
        return round($ht * 1.085, 2);
    }


    private function normalizeCountry(string $country): string
    {
        $value = mb_strtolower(trim($country));

        return match (true) {
            $value === 'fr',
            $value === 'france',
            str_contains($value, 'réunion'),
            str_contains($value, 'reunion'),
            str_contains($value, 'guadeloupe'),
            str_contains($value, 'martinique'),
            str_contains($value, 'guyane'),
            str_contains($value, 'mayotte') => 'FR',
            default => strtoupper($country),
        };
    }

    private function resolveZone(string $sellerTerritory, string $buyerCountry, string $buyerPostal): string
    {
        if ($buyerCountry !== 'FR') {
            return 'international_zone_2';
        }

        $origin = $sellerTerritory;
        $destination = $this->territoryFromPostalCode($buyerPostal);

        if ($destination === 'france') {
            return 'france';
        }

        if ($destination === null) {
            return 'france';
        }

        if ($origin === $destination) {
            return 'intra_om';
        }

        if ($this->isProximityRelation($origin, $destination)) {
            return 'outre_mer_proximite';
        }

        return 'outre_mer_eloigne';
    }

    private function territoryFromPostalCode(string $postalCode): ?string
    {
        $postal = preg_replace('/\D/', '', $postalCode);

        return match (true) {
            str_starts_with($postal, '971') => 'guadeloupe',
            str_starts_with($postal, '972') => 'martinique',
            str_starts_with($postal, '973') => 'guyane',
            str_starts_with($postal, '974') => 'reunion',
            str_starts_with($postal, '976') => 'mayotte',
            strlen($postal) === 5 => 'france',
            default => null,
        };
    }

    private function isProximityRelation(string $origin, string $destination): bool
    {
        $pair = [$origin, $destination];
        sort($pair);

        return in_array(implode('-', $pair), [
            'mayotte-reunion',
            'guadeloupe-martinique',
        ], true);
    }

    private function priceHt(string $zone, float $weight): float
    {
        $tables = [
            'intra_om' => [
                0.25 => 6.84, 0.50 => 7.71, 0.75 => 8.60, 1 => 9.34, 2 => 10.48,
                3 => 11.49, 4 => 12.54, 5 => 13.54, 6 => 14.17, 7 => 15.16,
                8 => 16.15, 9 => 17.17, 10 => 18.17, 11 => 18.79, 12 => 19.77,
                13 => 20.74, 14 => 21.75, 15 => 22.73, 16 => 23.70, 17 => 24.68,
                18 => 25.66, 19 => 26.65, 20 => 27.62, 21 => 28.33, 22 => 29.29,
                23 => 30.28, 24 => 31.25, 25 => 32.19, 26 => 33.19, 27 => 34.13,
                28 => 35.11, 29 => 36.12, 30 => 37.05,
            ],
            'france' => [
                0.50 => 10.86, 1 => 16.46, 2 => 22.43, 3 => 28.41, 4 => 34.39,
                5 => 38.61, 6 => 46.37, 7 => 52.32, 8 => 56.96, 9 => 62.64,
                10 => 69.45, 15 => 97.31, 20 => 125.22, 25 => 156.65, 30 => 189.29,
            ],
            'outre_mer_proximite' => [
                0.50 => 7.37, 1 => 8.87, 2 => 10.36, 3 => 11.88, 4 => 12.77,
                5 => 14.21, 6 => 16.38, 7 => 17.83, 8 => 19.21, 9 => 19.93,
                10 => 21.36, 15 => 24.55, 20 => 25.94, 25 => 28.37, 30 => 30.82,
            ],
            'outre_mer_eloigne' => [
                0.50 => 12.89, 1 => 20.03, 2 => 35.60, 3 => 51.14, 4 => 63.81,
                5 => 78.69, 6 => 97.86, 7 => 113.42, 8 => 127.94, 9 => 138.24,
                10 => 153.12, 15 => 235.13, 20 => 299.01, 25 => 373.16, 30 => 447.28,
            ],
            'international_zone_2' => [
                0.50 => 34.70, 1 => 40.95, 2 => 53.62, 3 => 66.27, 4 => 78.93,
                5 => 91.57, 6 => 104.23, 7 => 116.91, 8 => 129.51, 9 => 142.20,
                10 => 154.78, 15 => 217.33, 20 => 279.95, 25 => 342.49, 30 => 405.09,
            ],
        ];

        if (!isset($tables[$zone])) {
            throw new RuntimeException('Zone Colissimo inconnue.');
        }

        foreach ($tables[$zone] as $limit => $price) {
            if ($weight <= (float) $limit) {
                return $price;
            }
        }

        throw new RuntimeException('Poids Colissimo supérieur à 30 kg.');
    }

    private function normalizeTerritory(string $territory): string
    {
        $value = mb_strtolower(trim($territory));

        return match (true) {
            str_contains($value, 'réunion'), str_contains($value, 'reunion') => 'reunion',
            str_contains($value, 'mayotte') => 'mayotte',
            str_contains($value, 'martinique') => 'martinique',
            str_contains($value, 'guadeloupe') => 'guadeloupe',
            str_contains($value, 'guyane') => 'guyane',
            default => 'reunion',
        };
    }
}
