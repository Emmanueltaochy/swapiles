<?php

namespace App\Support;

use App\Notifications\AdminEventNotification;
use Illuminate\Support\Facades\Notification;

class AdminEvent
{
    public static function notify(string $title, string $message, ?string $url = null): void
    {
        try {
            Notification::route('mail', 'cabinet@taochyconsulting.fr')
                ->notify(new AdminEventNotification($title, $message, $url));
        } catch (\Throwable $e) {
            report($e);
        }
    }
}
