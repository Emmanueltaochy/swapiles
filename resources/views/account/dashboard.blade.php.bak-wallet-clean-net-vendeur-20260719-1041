@php
    $dashboardUser = auth()->user();

    $dashboardSellerTransactions = \App\Models\Transaction::query()
        ->where('seller_id', $dashboardUser->id)
        ->get();

    $dashboardWalletPendingAmount = $dashboardSellerTransactions
        ->filter(fn ($transaction) => $transaction->status === 'paid')
        ->sum(fn ($transaction) => $transaction->seller_amount > 0
            ? $transaction->seller_amount
            : max(0, ($transaction->amount ?? 0) - ($transaction->commission ?? 0) - ($transaction->buyer_protection_fee ?? 0) - ($transaction->shipping_fee ?? 0))
        );

    $dashboardWalletAvailableAmount = $dashboardSellerTransactions
        ->filter(fn ($transaction) => $transaction->status === 'completed' && !empty($transaction->released_at))
        ->sum(fn ($transaction) => $transaction->seller_amount > 0
            ? $transaction->seller_amount
            : max(0, ($transaction->amount ?? 0) - ($transaction->commission ?? 0) - ($transaction->buyer_protection_fee ?? 0) - ($transaction->shipping_fee ?? 0))
        );
@endphp

