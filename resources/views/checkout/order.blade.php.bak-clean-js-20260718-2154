        const value = String(field.value || '').trim();

        const required =
            placeholder.includes('*') ||
            ['buyer_phone', 'shipping_phone', 'phone', 'buyer_full_name', 'shipping_address_line1', 'shipping_postal_code', 'shipping_city', 'shipping_territory'].includes(name);

        if (!required) return;

        if (value) return;

        const wrapper = field.closest('div') || field;

        field.classList.add('border-red-500', 'ring-2', 'ring-red-100');
