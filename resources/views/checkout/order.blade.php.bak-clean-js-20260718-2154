<script>
document.addEventListener('DOMContentLoaded', function () {
    /*
     * 1. Champs obligatoires en rouge si erreur de validation
     */
    const hasErrorAlert = [...document.querySelectorAll('body *')]
        .some(el => (el.textContent || '').includes('Ce champ est obligatoire'));

    const requiredFields = [
        'buyer_full_name',
        'buyer_phone',
        'shipping_address_line1',
        'shipping_postal_code',
        'shipping_city',
        'shipping_territory',
        'delivery_method'
    ];

    if (hasErrorAlert) {
        requiredFields.forEach(function (name) {
            const fields = document.querySelectorAll(`[name="${name}"]`);

            fields.forEach(function (field) {
                let isEmpty = false;

                if (field.type === 'radio') {
                    isEmpty = !document.querySelector(`[name="${name}"]:checked`);
                } else {
                    isEmpty = !String(field.value || '').trim();
                }

                if (isEmpty) {
                    const wrapper = field.closest('label, div') || field;

                    field.classList.add(
                        'border-red-500',
                        'ring-2',
                        'ring-red-100'
                    );

                    wrapper.classList.add(
                        'border-red-500',
                        'ring-2',
                        'ring-red-100'
                    );

                    if (!wrapper.querySelector('.field-error-message')) {
                        const error = document.createElement('p');
                        error.className = 'field-error-message mt-2 text-sm font-bold text-red-600';
                        error.textContent = 'Ce champ est obligatoire.';
                        wrapper.appendChild(error);
                    }
                }
            });
        });
    }

    /*
     * 2. Déplacer le bouton de paiement dans le bloc Récapitulatif
     */
    const recapTitle = [...document.querySelectorAll('h1, h2, h3, p, div')]
        .find(el => (el.textContent || '').trim() === 'Récapitulatif');

    const payButtons = [...document.querySelectorAll('button[type="submit"]')]
        .filter(btn =>
            (btn.textContent || '').includes('Continuer vers le paiement')
            || (btn.textContent || '').includes('Payer')
        );

    if (recapTitle && payButtons.length) {
        const recapCard = recapTitle.closest('.bg-white, .rounded-3xl, section, div');
        const payButton = payButtons[payButtons.length - 1];

        if (recapCard && !recapCard.contains(payButton)) {
            payButton.classList.add('w-full', 'mt-6');
            recapCard.appendChild(payButton);
        }
    }

    /*
     * 3. Message acheteur si livraison plus chère que le produit
     */
    const bodyText = document.body.innerText || '';

    function extractAmount(label) {
        const regex = new RegExp(label + '\\\\s*([0-9]+(?:,[0-9]{1,2})?)\\\\s*€', 'i');
        const match = bodyText.match(regex);
        if (!match) return 0;
        return parseFloat(match[1].replace(',', '.')) || 0;
    }

    const itemAmount = extractAmount('Prix article');
    const shippingAmount =
        extractAmount('Livraison') ||
        extractAmount('Colissimo');

    if (itemAmount > 0 && shippingAmount > itemAmount && recapTitle) {
        const recapCard = recapTitle.closest('.bg-white, .rounded-3xl, section, div');

        if (recapCard && !document.getElementById('shipping-more-expensive-warning')) {
            const warning = document.createElement('div');
            warning.id = 'shipping-more-expensive-warning';
            warning.className = 'mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-900';
            warning.innerHTML = `
                <p class="font-extrabold">💡 Conseil livraison</p>
                <p class="mt-1 text-sm leading-relaxed">
                    La livraison coûte plus cher que le produit.
                    Nous vous conseillons de privilégier la remise en main propre si possible.
                </p>
            `;

            const securityBox = [...recapCard.querySelectorAll('div, p')]
                .find(el => (el.textContent || '').includes('Le paiement est sécurisé'));

            if (securityBox) {
                securityBox.parentNode.insertBefore(warning, securityBox);
            } else {
                recapCard.appendChild(warning);
            }
        }
    }
});
</script>
