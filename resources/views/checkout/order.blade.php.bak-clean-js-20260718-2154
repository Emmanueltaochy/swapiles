<script>
(function () {
    function moneyToNumber(text) {
        if (!text) return 0;
        const match = String(text).match(/([0-9]+(?:[,.][0-9]{1,2})?)\s*€/);
        return match ? parseFloat(match[1].replace(',', '.')) : 0;
    }

    function findRecapCard() {
        const titles = Array.from(document.querySelectorAll('h1, h2, h3, p, div, span'));
        const recapTitle = titles.find(el => (el.textContent || '').trim() === 'Récapitulatif');
        if (!recapTitle) return null;

        let el = recapTitle;
        while (el && el !== document.body) {
            const text = el.innerText || '';
            if (
                text.includes('Récapitulatif') &&
                text.includes('Prix article') &&
                text.includes('Total à payer')
            ) {
                return el;
            }
            el = el.parentElement;
        }

        return recapTitle.closest('section, div');
    }

    function addBuyerShippingWarning() {
        const recapCard = findRecapCard();
        if (!recapCard) return;

        if (document.getElementById('shipping-more-expensive-warning')) return;

        let itemAmount = 0;
        let shippingAmount = 0;

        const rows = Array.from(recapCard.querySelectorAll('div, p, span'));
        rows.forEach(function (el) {
            const text = el.innerText || '';

            if (text.includes('Prix article')) {
                itemAmount = moneyToNumber(text);
            }

            if (text.includes('Livraison') || text.includes('Colissimo')) {
                shippingAmount = moneyToNumber(text);
            }
        });

        if (!(itemAmount > 0 && shippingAmount > itemAmount)) return;

        const warning = document.createElement('div');
        warning.id = 'shipping-more-expensive-warning';
        warning.className = 'mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-amber-900';
        warning.innerHTML = `
            <p class="font-extrabold">💡 Conseil livraison</p>
            <p class="mt-1 text-sm leading-relaxed">
                La livraison coûte plus cher que le produit.
                Nous vous conseillons de privilégier la remise en main propre si possible.
            </p>
        `;

        const securityBox = Array.from(recapCard.querySelectorAll('div, p'))
            .find(el => (el.innerText || '').includes('Le paiement est sécurisé'));

        if (securityBox) {
            const box = securityBox.closest('div') || securityBox;
            box.parentNode.insertBefore(warning, box);
        } else {
            recapCard.appendChild(warning);
        }
    }

    function movePaymentButtonToRecap() {
        const recapCard = findRecapCard();
        if (!recapCard) return;

        const buttons = Array.from(document.querySelectorAll('button[type="submit"]'))
            .filter(btn => {
                const text = btn.innerText || '';
                return text.includes('Payer') || text.includes('Continuer vers le paiement');
            });

        if (!buttons.length) return;

        const payButton = buttons[0];

        if (recapCard.contains(payButton)) return;

        payButton.classList.add(
            'w-full',
            'mt-6',
            'rounded-2xl',
            'bg-teal-700',
            'hover:bg-teal-800',
            'text-white',
            'font-extrabold',
            'text-xl',
            'py-5',
            'shadow-md',
            'transition'
        );

        const securityBox = Array.from(recapCard.querySelectorAll('div, p'))
            .find(el => (el.innerText || '').includes('Le paiement est sécurisé'));

        if (securityBox) {
            const box = securityBox.closest('div') || securityBox;
            box.insertAdjacentElement('afterend', payButton);
        } else {
            recapCard.appendChild(payButton);
        }
    }

    function markMissingFieldsRed() {
        const errorText = document.body.innerText || '';

        if (!errorText.includes('Ce champ est obligatoire')) return;

        const requiredNames = [
            'buyer_full_name',
            'buyer_phone',
            'shipping_address_line1',
            'shipping_postal_code',
            'shipping_city',
            'shipping_territory',
            'delivery_method'
        ];

        requiredNames.forEach(function (name) {
            const fields = Array.from(document.querySelectorAll(`[name="${name}"]`));
            if (!fields.length) return;

            let missing = false;

            const first = fields[0];

            if (first.type === 'radio') {
                missing = !document.querySelector(`[name="${name}"]:checked`);
            } else {
                missing = !String(first.value || '').trim();
            }

            if (!missing) return;

            fields.forEach(function (field) {
                const wrapper = field.closest('label') || field.closest('div') || field;

                field.classList.add('border-red-500', 'ring-2', 'ring-red-100');

                if (wrapper !== field) {
                    wrapper.classList.add('border-red-500', 'ring-2', 'ring-red-100');
                }

                if (!wrapper.querySelector('.swapiles-field-error')) {
                    const msg = document.createElement('p');
                    msg.className = 'swapiles-field-error mt-2 text-sm font-bold text-red-600';
                    msg.textContent = 'Ce champ est obligatoire.';
                    wrapper.appendChild(msg);
                }
            });
        });
    }

    function runCheckoutVisualFixes() {
        addBuyerShippingWarning();
        movePaymentButtonToRecap();
        markMissingFieldsRed();
    }

    document.addEventListener('DOMContentLoaded', runCheckoutVisualFixes);
    window.addEventListener('load', runCheckoutVisualFixes);
    window.addEventListener('pageshow', runCheckoutVisualFixes);

    setTimeout(runCheckoutVisualFixes, 300);
    setTimeout(runCheckoutVisualFixes, 1000);
})();
</script>
<!-- SWAPILES_CHECKOUT_VISUAL_FIX_END -->


