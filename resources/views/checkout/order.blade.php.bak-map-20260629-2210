<script>
document.addEventListener('DOMContentLoaded', () => {
    const deliveryRadios = document.querySelectorAll('input[name="delivery_method"]');
    const colissimoTypeRadios = document.querySelectorAll('input[name="colissimo_delivery_type"]');
    const addressBlock = document.getElementById('colissimo-address-block');
    const pickupSearch = document.getElementById('pickup-search');
    const pickupResults = document.getElementById('pickup-results');
    const loadPickups = document.getElementById('load-pickups');

    const pickupFields = {
        id: document.querySelector('[name="pickup_id"]'),
        name: document.querySelector('[name="pickup_name"]'),
        address: document.querySelector('[name="pickup_address"]'),
        postal: document.querySelector('[name="pickup_postal_code"]'),
        city: document.querySelector('[name="pickup_city"]'),
        country: document.querySelector('[name="pickup_country"]'),
        type: document.querySelector('[name="pickup_type"]'),
    };

    function checkedValue(name) {
        const el = document.querySelector(`input[name="${name}"]:checked`);
        return el ? el.value : null;
    }

    function toggleBlocks() {
        const delivery = checkedValue('delivery_method');
        const colissimoType = checkedValue('colissimo_delivery_type');

        if (addressBlock) {
            addressBlock.classList.toggle('hidden', delivery !== 'colissimo');
        }

        if (pickupSearch) {
            pickupSearch.classList.toggle('hidden', delivery !== 'colissimo' || colissimoType !== 'pickup');
        }
    }

    deliveryRadios.forEach(el => el.addEventListener('change', toggleBlocks));
    colissimoTypeRadios.forEach(el => el.addEventListener('change', toggleBlocks));
    toggleBlocks();

    if (loadPickups) {
        loadPickups.addEventListener('click', async () => {
            const zip = document.querySelector('[name="shipping_postal_code"]')?.value || '';
            const city = document.querySelector('[name="shipping_city"]')?.value || '';
            const address = document.querySelector('[name="shipping_address_line1"]')?.value || '';

            if (!zip || !city) {
                pickupResults.innerHTML = '<div class="rounded-xl bg-red-50 text-red-700 p-3 text-sm font-bold">Renseignez le code postal et la ville avant de rechercher.</div>';
                return;
            }

            pickupResults.innerHTML = '<div class="text-sm text-gray-500 font-bold">Recherche des points retrait...</div>';

            try {
                const response = await fetch('/api/colissimo/points-relais?' + new URLSearchParams({
                    address: address,
                    zip_code: zip,
                    city: city,
                    country_code: 'FR',
                    weight_kg: '{{ $listing->weight_kg ?: 0.5 }}'
                }));

                const json = await response.json();

                if (!json.ok || !json.points || json.points.length === 0) {
                    pickupResults.innerHTML = '<div class="rounded-xl bg-amber-50 text-amber-700 p-3 text-sm font-bold">Aucun point retrait trouvé pour cette adresse.</div>';
                    return;
                }

                pickupResults.innerHTML = '';

                json.points.forEach(point => {
                    const div = document.createElement('label');
                    div.className = 'block rounded-2xl border border-gray-200 p-3 cursor-pointer hover:border-teal-400';

                    div.innerHTML = `
                        <div class="flex gap-3">
                            <input type="radio" name="pickup_choice" value="${point.id}" class="mt-1 text-teal-700 focus:ring-teal-600">
                            <div>
                                <div class="font-extrabold text-gray-900">${point.name || 'Point retrait'}</div>
                                <div class="text-sm text-gray-500 mt-1">${point.address || ''}<br>${point.postal_code || ''} ${point.city || ''}</div>
                                ${point.distance ? `<div class="text-xs text-teal-700 font-bold mt-1">${point.distance} m</div>` : ''}
                            </div>
                        </div>
                    `;

                    const radio = div.querySelector('input');

                    radio.addEventListener('change', () => {
                        pickupFields.id.value = point.id || '';
                        pickupFields.name.value = point.name || '';
                        pickupFields.address.value = point.address || '';
                        pickupFields.postal.value = point.postal_code || '';
                        pickupFields.city.value = point.city || '';
                        pickupFields.country.value = point.country || 'FR';
                        pickupFields.type.value = point.type || '';
                    });

                    pickupResults.appendChild(div);
                });
            } catch (e) {
                pickupResults.innerHTML = '<div class="rounded-xl bg-red-50 text-red-700 p-3 text-sm font-bold">Erreur pendant la recherche Colissimo.</div>';
            }
        });
    }
});
</script>

